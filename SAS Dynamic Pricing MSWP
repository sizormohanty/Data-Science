/*Generating Exception List*/ 
PROC SQL;
   CREATE TABLE WORK.Exception_List_Analysis1 AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          t1.MS_WPID, 
          t1.DP_SKU, 
          t1.SKU_Description,
		  t1.COLLECTION_ITEM_SKU_NUM, 
          t1.DP_CHAIN_RETAIL, 
		  /* Chain to Reg */
          t1.DP_REG_PRICE,  
          t1.DP_CHAIN_COST, 
          t1.Overall_Coupon_Rate, 
          t1.Overall_Break_Even, 
          t1.SKU_Freight, 
          t1.BBB_Min, 
          t1.BBB_PRICE_AMT, 
          t1.DP_CUR_WEB_PRICE, 
          t1.Reference_Price, 
          t1.MA_3, 
          t1.MA_7, 
          t1.AFLT_PRICE_AMT, 
          t1.Suggested_Price, 
          (Case When (T2.ALLOW_PRICE_INCREASE= 'N' and t1.Suggested_Price GT t1.DP_CUR_WEB_PRICE) Then "R03" 
                  When t4.sku_num NE . and t1.Suggested_Price GT t4.MAX_PRICE and datepart(in_effect_until) >=  &today2 Then "R03"
                  When t1.Suggested_Price EQ t1.DP_CUR_WEB_PRICE Then "R01"
                  When t1.Suggested_Price LT t1.BBB_Min Then "R02"
                  Else "Rok" End ) LABEL="Post_Price" AS Post_Price_Flag, 
          (Case When t1.DP_CUR_WEB_PRICE LT t1.BBB_Min Then "Y" 
		   		Else "N" End) LABEL="BBM_Buyer_Below_Min_Flag" AS BBM_Buyer_Below_Min_Flag,
          ("NA") LABEL="Amazon_Below_MAP_Flag" AS Amazon_Below_MAP_Flag, 
           /* Chain to Reg */
		  (Case When Abs((/*t1.DP_CHAIN_RETAIL*/t1.DP_REG_PRICE-t1.DP_CUR_WEB_PRICE)//*t1.DP_CHAIN_RETAIL*/t1.DP_REG_PRICE) GT &PPC_var Then "Y" 
				Else "N" End) LABEL="PPC_Permanent_Price_Change_Flag" AS PPC_Permanent_Price_Change_Flag, 

		  (Case When Abs((t1.AFLT_PRICE_AMT-t1.DP_CUR_WEB_PRICE)/t1.DP_CUR_WEB_PRICE) GT &BPC_var Then "Y" 
				Else "N" End) LABEL="BPC_Bad_Price_Candidate_Flag" AS BPC_Bad_Price_Candidate_Flag, 
          (Case When t1.Reference_Price LT t1.DP_CHAIN_COST Then "Y" 
				Else "N" End) LABEL= "RBC_Reference_Price_Below_Cost" AS RBC_Reference_Price_Below_Cost, 
		  t1.Current_Promo_Flag,
		  t1.Upcoming_Promo_Filter,
		  t1.Regular_Promo_Filter,
		  t1.MAP_FLAG,
		  t1.EM_FLAG,
		  t1.VDC_WEB_FLAG,
		  t1.No_Online_Inv_Flag,
		  t1.Chain_Status_Flag,
		  t1.Coll_excl_Flag,
          t1.PIM_VENDOR_NAME,
		  &exception_dt   AS Exception_list_Date,
		  t1.Code_Path,
	  	  t1.Reference_Price_Competitor,
	  	  t1.AFLT_PRICE_AMT_Competitor,
		  t1.PMR_AFLT_WEB_NM,
		  t1.DP_DY_PRICE_STRTS, 
          t1.DP_ENDTS,
		  t1.Scenario ,
		  t1.VDC_IND, 
	      t1.Web_Only_Ind, 
	   	  t1.In_Store_Ind,
			t1.SKU_sale_Type
      FROM WORK.ROUNDING t1
      left join work.depts t2 on t1.dp_department = t2.department_cd
      left join work.no_price_increase t4 on t4.sku_num = t1.dp_sku;
      
QUIT;


