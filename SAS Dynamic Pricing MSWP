PROC SQL;
   CREATE TABLE WORK.Guard_Rails AS 
   SELECT DISTINCT t1.DP_STORE, 
          	t1.DP_DEPARTMENT, 
          	t1.DP_SUB_DEPARTMENT, 
          	t1.DP_CLASS, 
          	t1.DP_VENDOR,
			t1.DP_VENDOR_NAME , 
