/*Getting the Reference Price only for the SKUs with Code Path 3*/
PROC SQL;
   CREATE TABLE WORK.Reference_Price_MSWP AS 
   SELECT distinct t1.dp_SKU as ITEM_SKU_NUM, 
   					t1.MA_7, 
          			t1.MA_3, 
          			t1.AFLT_PRICE_AMT,
					t1.AFLT_PRICE_AMT_Competitor,
					t1.Reference_Price,
					t1.Reference_Price_Competitor,
   					t1.MS_WPID
   from WORK.Remove_Promo_SKUs t1;
QUIT;

/*calculate integer portion of reference price*/
PROC SQL;
   CREATE TABLE WORK.MSWP_SKU_Ref_Price AS 
   SELECT t1.MS_WPID, 
          t1.ITEM_SKU_NUM, 
          t1.Reference_Price,
          (Int(t1.Reference_Price)) AS Integer_portion		
   FROM WORK.REFERENCE_PRICE_MSWP t1;
quit;


/*Calculating the Mode(using Integer Portion of Reference Price) and 
the Average(using the Reference price) 
If an MSWP have multiple Modes, then the table MANY_MODES reflects that */
ODS OUTPUT MODES=MANY_MODES;
proc univariate data=WORK.MSWP_SKU_Ref_Price modes ;
     class MS_WPID;
     var Integer_portion;
     output out=WORK.MODES1 mode=Mode n=Count;
run;
ODS OUTPUT CLOSE;

proc univariate data=WORK.MSWP_SKU_Ref_Price modes noprint;
     class MS_WPID;
     var Reference_Price;
     output out=WORK.MODES2 mean=Average;
run;

/* calculating the MSWP reference price */
Proc SQL;
	CREATE TABLE WORK.MSWP_SKU_Ref_Price2 AS 
  	SELECT distinct t1.MS_WPID,
  		   t1.ITEM_SKU_NUM,
		   t5.AFLT_PRICE_AMT,
		   t5.MA_7, 
           t5.MA_3,
		   t1.Reference_Price, 
  		   t1.Integer_portion,
		   t2.mode,
		   t2.Count as Count1,
		   t4.Count as Count2 ,
		   t3.Average,
		   a.no_modes,
		   (case when t2.mode =. then t3.Average /*if no mode, then average*/
		   		when t4.count = 1 then t3.Average /*if mode is from 1 SKU only, then use average*/
		   		when a.no_modes NE 1 then t3.Average /*if multiple modes, then use average*/
		   		when t4.Count/t2.Count < 0.2 then t3.Average	/*if mode is less than 20% of the SKUS in MSWP, then ignore Mode and use Average*/	   
		   		else t2.mode end) LABEl ="MSWP_Ref_Price" as MSWP_Ref_Price
   	FROM WORK.MSWP_SKU_Ref_Price T1
	INNER JOIN WORK.MODES1 t2 ON t1.MS_WPID = t2.MS_WPID
	INNER JOIN WORK.MODES2 t3 ON t1.MS_WPID = t3.MS_WPID
	inner join (select input(MS_WPID, 8.) as MS_WPID,
						Mode, 
						Count 
				from WORK.MANY_MODES) t4 on t1.MS_WPID = t4.MS_WPID
	INNER JOIN (select input(MS_WPID, 8.) as MS_WPID, 
					Count (*) as no_modes 
				from WORK.MANY_MODES
				group by MS_WPID) a on t1.MS_WPID = a.MS_WPID
	left join WORK.Reference_Price_MSWP t5 on (t5.ITEM_SKU_NUM = t1.ITEM_SKU_NUM);
QUIT;

PROC SQL;
   	CREATE TABLE WORK.Code3_MSWPs_SKU_Count AS 
   	SELECT distinct MS_WPID, 
		  	count(*) as Current_No_SKUs_in_MSWP
	FROM WORK.MSWP_SKU_Ref_Price2
	Group by MS_WPID;
QUIT;

