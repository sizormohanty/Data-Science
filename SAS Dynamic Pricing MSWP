/* Applying Position Rules*/ 
PROC SQL;
   CREATE TABLE WORK.Position_Rules AS 
   SELECT DISTINCT t1.DP_STORE, 
		  	t1.DP_DEPARTMENT, 
     		t1.DP_SUB_DEPARTMENT, 
          	t1.DP_CLASS, 
          	t1.DP_VENDOR, 
			t1.DP_VENDOR_NAME ,
          	t1.MS_WPID, 
          	t1.DP_SKU, 
          	t1.SKU_Description, 
			/* Chain to Reg */
			t1.DP_REG_PRICE, 
          	t1.DP_CHAIN_RETAIL, 
          	t1.DP_CHAIN_COST, 
          	t1.DP_DY_PRICE_STRTS, 
          	t1.DP_ENDTS, 
          	t1.BBB_PRICE_AMT, 
          	t1.DP_CUR_WEB_PRICE, 
          	t1.Overall_Coupon_Rate, 
          	t1.Overall_Break_Even, 
          	t1.SKU_Freight, 
          	t1.BBB_Min, 
          	t1.Reference_Price, 
          	t1.MA_3, 
          	t1.MA_7, 
          	t1.AFLT_PRICE_AMT, 
          	(Case When t1.DP_CUR_WEB_PRICE GE t1.Range_Max Then 
             		(Case When t1.BBB_Min GE t1.Reference_Price Then '3'  
                  		 	When t1.BBB_Min GT t1.Reference_Price Then '4'
                  		 	When t1.BBB_Min EQ t1.Reference_Price Then '0'
             			 	Else '1' End)
           		Else 
             		(Case When t1.DP_CUR_WEB_PRICE Between t1.Range_Min And t1.Range_Max Then
             				(Case When t1.BBB_Min GT t1.Reference_Price Then '6'
                				 When t1.BBB_Min EQ t1.Reference_Price Then '0'
           					 	 Else '2' End)
            				Else '5' End)
           		 	End ) FORMAT=$2. LABEL="Scenario" AS Scenario, 
          
          	(Case When t1.DP_CUR_WEB_PRICE GE t1.Range_Max Then 
               	    (Case When t1.BBB_Min GE t1.Reference_Price Then t1.BBB_Min 
							Else t1.Range_Max End)
           			Else 
                  	   (Case When t1.DP_CUR_WEB_PRICE Between t1.Range_Min And t1.Range_Max 
							Then t1.DP_CUR_WEB_PRICE 
							Else t1.Range_Min End)
          			End) FORMAT=9.2 LABEL="Position_Rules" AS Position_Rules, 
          	t1.BUYER_NUMBER, 
          	t1.BUYER_NAME, 
          	t1.Range_Max, 
          	t1.Range_Min, 
          	t1.COLLECTION_ITEM_SKU_NUM,
		  	t1.Code_Path,
	  		t1.Reference_Price_Competitor,
	  		t1.AFLT_PRICE_AMT_Competitor,
			t1.PMR_AFLT_WEB_NM,
	  		t1.Current_Promo_Flag,
			t1.Upcoming_Promo_Filter,
			t1.Regular_Promo_Filter,
			t1.MAP_FLAG,
			t1.EM_FLAG,
			t1.VDC_WEB_FLAG,
			t1.No_Online_Inv_Flag,
			t1.Chain_Status_Flag,
			t1.Coll_excl_Flag,
			t1.VDC_IND, 
	        t1.Web_Only_Ind, 
	   	    t1.In_Store_Ind,
			t1.SKU_sale_Type
      FROM WORK.GUARD_RAILS t1;
QUIT;

/*Applying Max weekly Change*/
PROC SQL;
   CREATE TABLE WORK.Max_Weekly_Change AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR,
		  t1.DP_VENDOR_NAME ,
          t1.MS_WPID, 
          t1.DP_SKU, 
          t1.SKU_Description, 
		  /* Chain to Reg */
		  t1.DP_REG_PRICE, 
          t1.DP_CHAIN_RETAIL, 
          t1.DP_CHAIN_COST, 
          t1.BBB_PRICE_AMT, 
          t1.DP_CUR_WEB_PRICE, 
          t1.BBB_Min, 
          t1.Overall_Coupon_Rate, 
          t1.Overall_Break_Even, 
          t1.SKU_Freight, 
          t1.Reference_Price, 
          t1.MA_3, 
          t1.MA_7, 
          t1.AFLT_PRICE_AMT, 
          t1.DP_DY_PRICE_STRTS, 
          t1.DP_ENDTS, 
          t1.Position_Rules, 
          (Case When ABS((t1.DP_CUR_WEB_PRICE-t1.Position_Rules)/t1.DP_CUR_WEB_PRICE) LE &Weekly_Change 
            		Then t1.Position_Rules 
		    	Else (Case When t1.Position_Rules LE (1-&Weekly_Change)*t1.DP_CUR_WEB_PRICE 
                 				Then (1-&Weekly_Change)*t1.DP_CUR_WEB_PRICE 
				 		Else (1+&Weekly_Change)*t1.DP_CUR_WEB_PRICE End)
            	End) FORMAT=9.2 LABEL="Max_Weekly_Change" AS Max_Weekly_Change, 
          t1.Scenario, 
          t1.BUYER_NUMBER, 
          t1.BUYER_NAME, 
          t1.COLLECTION_ITEM_SKU_NUM,
		  t1.Code_Path,
	  	  t1.Reference_Price_Competitor,
	  	  t1.AFLT_PRICE_AMT_Competitor,
		  t1.PMR_AFLT_WEB_NM,
	  	  t1.Current_Promo_Flag,
		  t1.Upcoming_Promo_Filter,
		  t1.Regular_Promo_Filter,
	  	  t1.MAP_FLAG,
		  t1.EM_FLAG,
		  t1.VDC_WEB_FLAG,
		  t1.No_Online_Inv_Flag,
		  t1.Chain_Status_Flag,
		  t1.Coll_excl_Flag,
		  t1.VDC_IND, 
	      t1.Web_Only_Ind, 
	   	  t1.In_Store_Ind,
			t1.SKU_sale_Type
      FROM WORK.POSITION_RULES t1;
QUIT;

