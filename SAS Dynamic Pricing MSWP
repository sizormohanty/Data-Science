/*Extracting SKU-Wise Store wise-on Hand On-Order Units*/
PROC SQL;
   CREATE TABLE WORK.Distinct_SKUs_Remove AS 
   SELECT DISTINCT t1.SKU_NUM as SKU
   FROM WORK.INV_File t1
   inner join WORK.JOIN t2 on t1.SKU_NUM = t2.ITEM_SKU_NUM
   inner join WORK.DEPTS T3 ON t2.DP_DEPARTMENT = T3.DEPARTMENT_CD
   left join WORK.STORE_EXCL T4 on t1.store_num = t4.store_num
   WHERE (t1.EOD_ON_HAND_UNITS > t3.MIN_INVENTORY or		
		 t1.EOD_PURCHASE_ON_ORDER_UNITS > 0 or	
		 t1.EOD_TRANSFER_OUT_UNITS > t3.MIN_INVENTORY) and t4.store_num = .;
QUIT;

/*Remove MSWPs for which the inventory SKUs are part of*/
PROC SQL;
   CREATE TABLE WORK.MSWP_REMOVE AS 
   SELECT DISTINCT t2.MSWP_ITEM_SKU_NUM
   FROM WORK.DISTINCT_SKUS_REMOVE t1
   INNER JOIN WORK.MSWP_SKUs t2 ON (t1.SKU = t2.ITEM_SKU_NUM);
QUIT;



/*Extracting SKUs with more than 500 units of ON HAND Inventory */
PROC SQL;
   CREATE TABLE WORK.Distinct_SKUs_Remove_500UOH AS 
   SELECT DISTINCT t1.SKU_NUM as SKU,
   					sum(t1.EOD_ON_HAND_UNITS) as  OH_Inv
   FROM WORK.INV_File t1
   inner join WORK.JOIN t2 on t1.SKU_NUM = t2.ITEM_SKU_NUM
   inner join WORK.DEPTS T3 ON t2.DP_DEPARTMENT = T3.DEPARTMENT_CD
   group by t1.SKU_NUM
   having calculated OH_Inv > 500;
QUIT;

/*Remove MSWPs for which the inventory SKUs are part of
THIS PART IS NOT WORKING BECAUSE WE ARE ONLY LOOKING AT MSWPS WITH VDC SKUS!!! */
PROC SQL;
   CREATE TABLE WORK.MSWP_REMOVE_500UOH AS 
   SELECT DISTINCT t2.MSWP_ITEM_SKU_NUM
   FROM WORK.DISTINCT_SKUS_REMOVE_500UOH t1
   INNER JOIN WORK.MSWP_SKUs t2 ON (t1.SKU = t2.ITEM_SKU_NUM);
QUIT;



/*Generating Exception List*/ 
PROC SQL;
   CREATE TABLE WORK.Exception_List_Analysis AS 
   SELECT DISTINCT t1.*,
		    /*t2.MSWP_ITEM_SKU_NUM as MSWP_w_store_inv,*/
   			(case when t2.MSWP_ITEM_SKU_NUM = . then "N"
				else "Y" end) as Store_Inv_Flag,
				
		    (case when t1.Code_Path = '44' and t33.SKU = . then "N"
		  		when t1.Code_Path = '44' and t33.SKU NE . then "Y"
				else "Y" end) as UOH_Inv500_Flag,
			"N" as Twenty_twenty_Flag

   FROM WORK.Exception_List_Analysis1 t1
   LEFT JOIN WORK.MSWP_REMOVE t2 ON (t1.MS_WPID = t2.MSWP_ITEM_SKU_NUM)
   LEFT JOIN WORK.Distinct_SKUs_Remove_500UOH t33 ON (t1.DP_SKU = t33.SKU);
