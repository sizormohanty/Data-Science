/*populating the calculated MWSP- or class- freight rate to SKU level*/
PROC SQL;
   CREATE TABLE WORK.SKU_Freight AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          t1.MS_WPID,    
		  t1.DP_SKU, 
          t1.SKU_Description, 
		  t1.SKU_TYPE,
          t1.DP_REG_PRICE, 
          t1.DP_CUR_WEB_PRICE, 
          t1.BBB_PRICE_AMT,         
          t1.AFLT_PRICE_AMT,           
          t1.COLLECTION_ITEM_SKU_NUM,
		  t1.No_SKUs_in_MSWP,
		  t1.MSWP_Ref_Price,
		  t1.Current_No_SKUs_in_MSWP,
		  t2.Gross_Frt_as_a_per_of_merch,
		  t3.MSWP_Freight_Rate,
		  cats(t1.DP_DEPARTMENT,t1.DP_SUB_DEPARTMENT,t1.DP_CLASS) as CODE,
		  t4.Class_Freight,
		  (case when t3.MSWP_Freight_Rate = . then t4.Class_Freight
		  		else t3.MSWP_Freight_Rate end) LABEl ="SKU_Freight" as SKU_Freight
	FROM WORK.GOOD_FOR_FREIGHT t1
	left join WORK.SKUs_w_Freight t2 on t1.DP_SKU = t2.SKU
	left join MSWP_Mean t3 on t3.MS_WPID = t1.MS_WPID
	left join Class_P1090_Mean  t4 on 
			t4.class_dist=cats(t1.DP_DEPARTMENT,t1.DP_SUB_DEPARTMENT,t1.DP_CLASS)  ;
QUIT;


