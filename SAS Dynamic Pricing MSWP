/*Generating Post Filter*/ 
PROC SQL;
   CREATE TABLE WORK.Post_Filter AS 
   SELECT DISTINCT t1.DP_STORE, 
          			t1.DP_DEPARTMENT, 
          			t1.DP_SUB_DEPARTMENT, 
          			t1.DP_CLASS, 
          			t1.DP_VENDOR, 
          			t1.MS_WPID, 
          			t1.DP_SKU, 
          			t1.SKU_Description,
          			t1.COLLECTION_ITEM_SKU_NUM, 
          			t1.DP_CHAIN_RETAIL, 
					/* Chain to Reg */
					t1.DP_REG_PRICE, 
          			t1.DP_CHAIN_COST, 
          			t1.BBB_Min, 
          			t1.Overall_Coupon_Rate, 
          			t1.Overall_Break_Even, 
          			t1.SKU_Freight, 
          			t1.BBB_PRICE_AMT, 
          			t1.DP_CUR_WEB_PRICE, 
          			t1.Reference_Price, 
          			t1.MA_3, 
          			t1.MA_7, 
          			t1.AFLT_PRICE_AMT, 
					t1.PIM_VENDOR_NAME, 
					t1.code_path,
					t1.Suggested_Price AS Dynamic_Price,
          			t1.DP_DY_PRICE_STRTS, 
          			t1.DP_ENDTS,
          			(t1.Scenario||'7') AS DP_DY_SET_RULECD, 
				    /* Reason_Code */
					 /* Reason_Code */
					(Case When t1.Reference_Price_Competitor = 'Amazon(SBA)' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "AH"
	  				  	  When t1.Reference_Price_Competitor = 'Amazon(SBA)' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "AL"

						  when  t1.Reference_Price_Competitor = 'Amazon(FBA)' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "FH"
				  		  When  t1.Reference_Price_Competitor = 'Amazon(FBA)' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "FL"

						  When  t1.Reference_Price_Competitor = 'Overstock' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "OH"
						  When  t1.Reference_Price_Competitor = 'Overstock' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "OL"

						  When  t1.Reference_Price_Competitor = 'Walmart' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "WH"
						  When  t1.Reference_Price_Competitor = 'Walmart' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "WL"

						  When  t1.Reference_Price_Competitor = 'Wayfair' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "YH"
						  When  t1.Reference_Price_Competitor = 'Wayfair' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "YL"

						  When  t1.Reference_Price_Competitor = 'Lowes' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "LH"
						  When  t1.Reference_Price_Competitor = 'Lowes' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "LL"

						  When  t1.Reference_Price_Competitor = 'HD' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "HH"
						  When  t1.Reference_Price_Competitor = 'HD' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "HL"

						  When  t1.Reference_Price_Competitor = 'Macys' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "MH"
						  When  t1.Reference_Price_Competitor = 'Macys' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "ML"

						  When  t1.Reference_Price_Competitor = 'Target' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "TH"
						  When  t1.Reference_Price_Competitor = 'Target' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "TL"
				
						  When  t1.Reference_Price_Competitor = 'ToysRUs' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "RH"
						  When  t1.Reference_Price_Competitor = 'ToysRUs' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "RL"
				
						  When  t1.Reference_Price_Competitor = 'eBags' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "EH"
						  When  t1.Reference_Price_Competitor = 'eBags' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "EL"

						  When  t1.Reference_Price_Competitor = 'Sears' and t1.Reference_Price > t1.DP_CUR_WEB_PRICE Then "SH"
						  When  t1.Reference_Price_Competitor = 'Sears' and t1.Reference_Price <= t1.DP_CUR_WEB_PRICE Then "SL"

				
						  else "??"  End) FORMAT=$2. LABEL= "Reason_Code" AS DP_DY_BUS_RSNCD,
					('N') AS DP_DY_CPN_EXCLU_IND,
					('YK') AS DP_DY_PRICE_RSNCD,
					t1.SKU_sale_Type,
					t1.PMR_AFLT_WEB_NM
      FROM WORK.Exception_List_Analysis t1
      WHERE t1.Post_Price_Flag = "Rok" AND
			t1.BBM_Buyer_Below_Min_Flag = "N" AND
			t1.PPC_Permanent_Price_Change_Flag = "N" AND
			t1.BPC_Bad_Price_Candidate_Flag = "N" AND
			t1.RBC_Reference_Price_Below_Cost = "N" AND
			t1.Current_Promo_Flag = "N" AND
			t1.Upcoming_Promo_Filter = "N" AND
			/*t1.Regular_Promo_Filter = "N" AND*/
			t1.MAP_FLAG = "N" AND
			t1.EM_FLAG = "N" AND			
			t1.Chain_Status_Flag="N" AND
			t1.Coll_excl_Flag = "N" AND
			(   t1.Store_Inv_Flag = "N" and
				t1.VDC_WEB_FLAG = "N" AND
			/*	t1.No_Online_Inv_Flag = "N" AND*/
				t1.code_path in ('3','77')) 			
	  ORDER BY t1.MS_WPID;
QUIT;

/* Calculating if a SKU is part of multiple MSWPs */
/* getting all SKUs with price recommendations */
PROC SQL;
   	CREATE TABLE WORK.MSWP_SKUs_w_Recos AS 
   	SELECT DISTINCT t1.DP_SKU
   	FROM WORK.Post_Filter t1;
QUIT;

/* Finding all MSWPs that these SKUs are part of */
PROC SQL;
   	CREATE TABLE WORK.MSWP_SKUs_w_Recos_MSWPs AS 
   	SELECT DISTINCT t1.MSWP_ITEM_SKU_NUM as MS_WPID, 
			t1.ITEM_SKU_NUM 
	FROM WORK.MSWP_SKUs  t1
    inner JOIN WORK.MSWP_SKUs_w_Recos t2 ON t1.ITEM_SKU_NUM = t2.DP_SKU;
QUIT;

/* getting the SKUs that are part of multiple MSWPs */
PROC SQL;
   	CREATE TABLE WORK.SKU_in_Multiple_MSWPs AS 
   	SELECT DISTINCT t1.ITEM_SKU_NUM , 
            (COUNT(t1.MS_WPID)) AS COUNT_of_MSWPs
   	FROM WORK.MSWP_SKUs_w_Recos_MSWPs t1
   	GROUP BY t1.ITEM_SKU_NUM
   	HAVING (CALCULATED COUNT_of_MSWPs) > 1;
QUIT;

/* getting all MSWPS where we have SKUs that belong to multiple MSWPs*/
PROC SQL;
   CREATE TABLE WORK.MSWPs_with_Multiple_SKUs AS 
   SELECT DISTINCT t1.MS_WPID
   FROM WORK.MSWP_SKUs_w_Recos_MSWPs t1
   INNER JOIN WORK.SKU_in_Multiple_MSWPs t2 ON (t1.ITEM_SKU_NUM  = t2.ITEM_SKU_NUM );
QUIT;


/* Calculating if a MSWP has received multiple Dynamic Prices */
/* checking that the SKUs received a Dynamic Price */
PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_NON_DUP_SKUS AS 
   SELECT DISTINCT t1.MS_WPID, 
          t1.Dynamic_Price
   FROM WORK.Post_filter t1
   WHERE t1.Dynamic_Price NOT = .;
QUIT;

/* checking that the SKUs only received 1 Dynamic Price */
PROC SQL;
   CREATE TABLE WORK.Single_DPs_Only AS 
   SELECT DISTINCT t1.MS_WPID, 
            (COUNT(t1.Dynamic_Price)) AS COUNT_of_Dynamic_Price
   FROM WORK.QUERY_FOR_NON_DUP_SKUS t1
   GROUP BY t1.MS_WPID
   HAVING (CALCULATED COUNT_of_Dynamic_Price) = 1;
QUIT;

/* MSWPs with only 1 BBBMin */
/* checking that the SKUs only received 1 BBB Min */
PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_NON_DUP_SKUS_0001 AS 
   SELECT DISTINCT t1.MS_WPID, 
           t1.BBB_Min
   FROM WORK.Post_filter t1
   WHERE t1.Dynamic_Price NOT = .;
QUIT;

PROC SQL;
   CREATE TABLE WORK.Single_BBB_Mins AS 
   SELECT DISTINCT t1.MS_WPID, 
            (COUNT(t1.BBB_Min)) AS COUNT_of_BBB_Min
   FROM WORK.QUERY_FOR_NON_DUP_SKUS_0001 t1
   GROUP BY t1.MS_WPID
   HAVING (CALCULATED COUNT_of_BBB_Min) = 1;
QUIT;

proc SQL;
	CREATE TABLE WORK.Single_MSWP_cost AS 
   	SELECT DISTINCT  t1.MS_WPID, 
		  count (distinct t1.DP_CHAIN_COST) as no_costs
    FROM WORK.Post_filter t1
	group by t1.MS_WPID
	having calculated no_costs >1;
Quit;

/*removing SKUs that belong to multiple MSWPs, or have multiple DP prices or multiple BBBMins*/
PROC SQL;
   	CREATE TABLE WORK.MSWP_Non_Dup_SKUs AS 
   	SELECT DISTINCT t1.*,
   				   (case when t2.MS_WPID = . then "N"
						else "Y" end) as Multiple_MSWPs_Flag,
				   (case when t3.MS_WPID = . then "Y"
						else "N" end) as Multiple_DP_Recos_Flag,
			   	   (case when t4.MS_WPID = . then "Y"
						else "N" end) as Multiple_BBBMin_Flag,
 				   (case when t5.MS_WPID = . then "N"
						else "Y" end) as Multiple_Cost_Flag
   	FROM WORK.Post_Filter t1
   	LEFT JOIN WORK.MSWPs_with_Multiple_SKUs t2 ON (t1.MS_WPID = t2.MS_WPID)
   	LEFT JOIN WORK.Single_DPs_Only t3 ON (t1.MS_WPID = t3.MS_WPID)
	LEFT JOIN WORK.Single_BBB_Mins t4 on (t1.MS_WPID = t4.MS_WPID)
	LEFT JOIN WORK.Single_MSWP_cost t5 on (t1.MS_WPID = t5.MS_WPID);
QUIT;

PROC SQL;
   	CREATE TABLE WORK.Final_Set_MSWP AS 
   	SELECT DISTINCT t1.*
    FROM WORK.MSWP_Non_Dup_SKUs t1
    Where t1.Multiple_MSWPs_Flag = "N" and
			t1.Multiple_DP_Recos_Flag= "N" and
			t1.Multiple_BBBMin_Flag= "N" and
			t1.Multiple_Cost_Flag = "N";
QUIT;

/* getting the highest CUR WEB PRICE... in case there are different current web prices within a given MSWP*/
PROC SQL;
   CREATE TABLE WORK.Max_Curr_Price AS 
   SELECT DISTINCT t1.MS_WPID, 
            (MAX(t1.DP_CUR_WEB_PRICE)) AS MAX_of_DP_CUR_WEB_PRICE
   FROM WORK.Final_Set_MSWP t1
   GROUP BY t1.MS_WPID;
QUIT;

PROC SQL;
   CREATE TABLE WORK.Max_Curr_Price_All_Data AS 
   SELECT DISTINCT t1.COLLECTION_ITEM_SKU_NUM, 
          t1.MS_WPID, 
          t1.DP_DEPARTMENT,
		  t1.DP_SKU, 
          t1.DP_CUR_WEB_PRICE, 
          t1.Dynamic_Price, 
          t1.MA_7, 
          t1.MA_3, 
          t1.AFLT_PRICE_AMT, 
          t1.Reference_Price, 
          t1.BBB_Min, 
          t1.DP_CHAIN_RETAIL, 
		   /* Chain to Reg */
		  t1.DP_REG_PRICE,
          t1.DP_CHAIN_COST, 
          t1.Overall_Coupon_Rate, 
          t1.Overall_Break_Even, 
          t1.SKU_Freight, 
          t1.DP_DY_BUS_RSNCD, 
          t1.DP_DY_CPN_EXCLU_IND, 
          t1.DP_DY_PRICE_RSNCD, 
          t1.DP_DY_SET_RULECD,
		  t1.DP_DY_PRICE_STRTS, 
          t1.DP_ENDTS,
		  t1.PIM_VENDOR_NAME,
		  t1.code_path,
		  t1.SKU_sale_Type
   FROM WORK.Final_Set_MSWP t1
   inner join WORK.MAX_CURR_PRICE t2 on t1.MS_WPID = t2.MS_WPID AND 
				t1.DP_CUR_WEB_PRICE = t2.MAX_of_DP_CUR_WEB_PRICE;
QUIT;

/* counting how many SKUs are in each MSWP - Max_Curr_Price_All_Data QUERY(after all exclusions) */
PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_ALL_DATA AS 
   SELECT DISTINCT t1.MS_WPID, 
            (COUNT(t1.MS_WPID)) AS COUNT_of_MSWP_AD
   FROM WORK.Max_Curr_Price_All_Data t1
   GROUP BY t1.MS_WPID;
QUIT;

/*counting how many SKUS are in each MSWP - Post Filter (after inventory) */
PROC SQL;
   CREATE TABLE WORK.QUERY_FOR_MSWP_RECOS AS 
   SELECT DISTINCT t1.MS_WPID, 
            (COUNT(t1.MS_WPID)) AS COUNT_of_MSWP_MR
   FROM WORK.post_filter t1
   GROUP BY t1.MS_WPID;
QUIT;

/* calculating the threshold*/
PROC SQL;
   CREATE TABLE WORK.Threshold_MSWPs AS 
   SELECT DISTINCT t1.MS_WPID, 
            (t1.COUNT_of_MSWP_AD/t2.COUNT_of_MSWP_MR) AS Threshold
   FROM WORK.QUERY_FOR_ALL_DATA t1
   INNER JOIN WORK.QUERY_FOR_MSWP_RECOS t2 ON (t1.MS_WPID = t2.MS_WPID)
   WHERE (CALCULATED Threshold) >= 0.2;
QUIT;

/*getting the final reco file for mswp logic*/
PROC SQL;
 	CREATE TABLE Final_Reco_MSWP AS 
	SELECT DISTINCT t4.COLLECTION_ITEM_SKU_NUM, 
          t4.MS_WPID, 
          t4.DP_SKU, 
          t4.SKU_Description, 
          t4.DP_DEPARTMENT, 
          t4.DP_CUR_WEB_PRICE,
		  (case When t3.Dynamic_Price =. Then t2.Dynamic_Price
		   		Else t3.Dynamic_Price 	End) AS DP_Price, 
          (case When t3.MA_7 =. Then t2.MA_7
		   		Else t3.MA_7 	End) AS MA_7,
		  (case When t3.MA_3 =. Then t2.MA_3
		   		Else t3.MA_3 	End) AS MA_3, 
          t3.AFLT_PRICE_AMT, 
		  (case When t3.Reference_Price =. Then t2.Reference_Price
		   		Else t3.Reference_Price 	End) AS Reference_Price, 
		  (case When t3.BBB_Min =. Then t2.BBB_Min
		   		Else t3.BBB_Min 	End) AS BBB_Min,
          t4.DP_CHAIN_RETAIL, 
		  /* Chain to Reg */
          t4.DP_REG_PRICE, 
          t4.DP_Chain_Cost, 
          (case when t5.Overall_Coupon_Rate = .  then t8.Overall_Coupon_Rate
				else t5.Overall_Coupon_Rate end) as Overall_Coupon_Rate,

          t4.Overall_Break_Even, 
		  (case When t3.SKU_Freight =. Then t2.SKU_Freight
			   	Else t3.SKU_Freight 	End) AS SKU_Freight, 
		  (case When t3.DP_DY_BUS_RSNCD = ' ' Then t2.DP_DY_BUS_RSNCD
		   		Else  t3.DP_DY_BUS_RSNCD 	End) AS DP_DY_BUS_RSNCD, 
          ('N') AS DP_DY_CPN_EXCLU_IND,
		  ('YK') AS DP_DY_PRICE_RSNCD,
		  (case When t3.DP_DY_SET_RULECD = ' ' Then t2.DP_DY_SET_RULECD
		   		Else  t3.DP_DY_SET_RULECD 	End) AS 'DP_DY_SET_RULECD 'n, 
          t4.DP_VENDOR_NAME as PIM_VENDOR_NAME,
		  (case When t3.DP_DY_PRICE_STRTS is NULL Then t2.DP_DY_PRICE_STRTS
		   		Else  t3.DP_DY_PRICE_STRTS 	End) AS DP_DY_PRICE_STRTS,
		  (case When t3.DP_ENDTS is NULL Then t2.DP_ENDTS
		   		Else  t3.DP_ENDTS 	End) AS DP_ENDTS,
		  (case When t4.DP_DEPARTMENT in (883) Then '77'
		   		Else '3' end) as code_path,
			t4.SKU_sale_Type
	FROM WORK.DISTINCT_PIM t4 
    inner JOIN WORK.Threshold_MSWPs t1 ON t4.MS_WPID = t1.MS_WPID 
	left join WORK.Max_Curr_Price_All_Data t2 on t2.MS_WPID=t4.MS_WPID
	left JOIN WORK.Final_Set_MSWP t3 ON (t4.MS_WPID = t3.MS_WPID and t4.ITEM_SKU_NUM = t3.DP_SKU)
	left join WORK.Remove_Promo_SKUs t5 on (t4.ITEM_SKU_NUM = t5.DP_SKU)
	left join WORK.mswp_coupon_rate t8 on t3.MS_WPID = t8.MS_WPID
    WHERE t4.MAP_FLAG = "N" and
			t4.EM_FLAG = "N" and
			t4.DP_CHAIN_STATUS IN  ('A','I','N') and
			t5.Current_Promo_Flag = "N" AND
			t5.Upcoming_Promo_Filter = "N";
	  /*Multi-SKU collection and Collection with Dupes excluded*/
QUIT;


/*checking the MSWP-level cost again*/
proc SQL;
	CREATE TABLE WORK.Single_MSWP_cost2 AS 
   	SELECT DISTINCT  t1.MS_WPID, 
		  count (distinct t1.DP_CHAIN_COST) as no_costs
    FROM WORK.Final_Reco_MSWP t1
	group by t1.MS_WPID
	having calculated no_costs >1;
Quit;

proc sql ;
	create table work.Final_Reco_MSWP1 as	
	select t1.*
	from work.Final_Reco_MSWP t1
	left join WORK.Single_MSWP_cost2 t2 on t1.MS_WPID = t2.MS_WPID
	where t2.MS_WPID = .;
quit;


proc sort data=Final_Reco_MSWP1 out=Final_Reco_MSWP nodupkey;
by DP_SKU;run;

PROC SQL;
   CREATE TABLE MSWP_reco_file_&today1  as
   SELECT DISTINCT
          	(t1.DP_Price) AS Post_Filter, 
          	(t1.DP_DY_BUS_RSNCD) AS Reason_Code, 
            (t1.DP_DY_CPN_EXCLU_IND) AS Coupon_Exclusion_Code, 
            (t1.AFLT_PRICE_AMT/t1.DP_Chain_Cost) AS Aff_Price_Over_Chain_Cost, 
            (t1.DP_CUR_WEB_PRICE/t1.BBB_Min) AS BBB_Over_BBB_Min, 
            (Abs((t1.DP_Chain_Retail-t1.DP_CUR_WEB_PRICE)/t1.DP_Chain_Retail)) AS Permanent_Price_Change, 
            (Abs(t1.AFLT_PRICE_AMT-t1.DP_CUR_WEB_PRICE)/t1.DP_CUR_WEB_PRICE) AS Bad_Price_Candidate, 
            (651) AS DP_STORE, 
            (t1.DP_DEPARTMENT) AS DP_DEPARTMENT, 
            (1) AS DP_SUB_DEPARTMENT, 
            (2) AS DP_CLASS, 
            (3) AS DP_VENDOR, 
            (t1.MS_WPID) AS MS_WPID, 
            (t1.DP_SKU) AS DP_SKU, 
            (t1.SKU_Description) AS SKU_Description, 
            (t1.DP_Chain_Retail) AS DP_CHAIN_RETAIL, 
			 /* Chain to Reg */
	    	(t1.DP_REG_PRICE),
            (t1.DP_Chain_Cost) AS DP_CHAIN_COST, 
            (2014-01-01) FORMAT=DATETIME. AS DP_PROMO_SRT_DT, 
            (2015-01-16) FORMAT=DATETIME. AS DP_PROMO_END_DT, 
            (t1.BBB_Min) AS BBB_Min, 
            (t1.Overall_Coupon_Rate) AS Overall_Coupon_Rate, 
            (t1.Overall_Break_Even) AS Overall_Break_Even, 
            (t1.SKU_Freight) AS SKU_Freight, 
            (t1.DP_CUR_WEB_PRICE) AS BBB_PRICE_AMT, 
            (t1.DP_CUR_WEB_PRICE) AS DP_CUR_WEB_PRICE, 
            (t1.Reference_Price) AS Reference_Price, 
            (1) AS Competition_Min, 
            (1) AS Competition_Max, 
            (1) AS Range_Max, 
            (1) AS Range_Min, 
            (t1.MA_3) AS MA_3, 
            (t1.MA_7) AS MA_7, 
            (t1.AFLT_PRICE_AMT) AS AFLT_PRICE_AMT, 
         	(&Reco_start_date) format=yymmdd10.2 LABEL="DP_DY_PRICE_STRTS" AS DP_DY_PRICE_STRTS, 
            (1) AS BUYER_NUMBER, 
            ('D700') AS BUYER_NAME, 
            (put(&Reco_end_date,yymmdd10.)||'-23.59.59.000000') FORMAT=$26. LABEL="DP_ENDTS" AS DP_ENDTS,
            (t1.DP_Price) AS Position_Rules, 
            (0.2) AS Max_Weekly_Change, 
            (0.5) AS Max_Overall_Change, 
            (t1.DP_CUR_WEB_PRICE) AS Suggested_Price, 
            (substr(t1.DP_DY_SET_RULECD,1)) AS Scenario, 
            (0) AS Competition_Delta, 
            (t1.PIM_VENDOR_NAME) AS PIM_VENDOR_NAME, 
            (t1.COLLECTION_ITEM_SKU_NUM) AS COLLECTION_ITEM_SKU_NUM,
		    t1.code_path,
			t1.SKU_sale_Type
	FROM Final_Reco_MSWP t1;
QUIT;

 PROC SQL;
   CREATE TABLE WORK.MSWP_reco_file AS 
   SELECT DISTINCT /* Multi_SKU_Web_Product_ID */
           (t1.MS_WPID) LABEL="Multi_SKU_Web_Product_ID" AS Multi_SKU_Web_Product_ID, 
          /* Collection# */
            (t1.COLLECTION_ITEM_SKU_NUM) LABEL="Collection#" AS Collection_num, 
          /* SKU# */
            (t1.DP_SKU) LABEL="SKU#" AS SKU_num, 
          /* SKU_Description */
            (t1.SKU_Description) LABEL="SKU_Description" AS SKU_Description, 
          /* Department */
            (t1.DP_DEPARTMENT) LABEL="Department" AS Department_cd, 
          /* Current_Web_Price */
            (t1.DP_CUR_WEB_PRICE) LABEL="Current_Web_Price" AS Current_Web_Price, 
          /* Dynamic_Price_Recommendation */
            (t1.Post_Filter) LABEL="Dynamic_Price_Recommendation" AS Dynamic_Price_Recommendation, 
          /* Percent_Change_Price */
            ((t1.Post_Filter-t1.DP_CUR_WEB_PRICE)/t1.DP_CUR_WEB_PRICE) FORMAT=PERCENT8.0 LABEL=
            "Percent Change (Dyanmic Price-Current Price)/Current Price" AS Percent_Change_Price, 
          /* Percent_Diff */
            ((t1.Post_Filter-t1.Reference_Price)/t1.Reference_Price) FORMAT=PERCENT8.1 LABEL=
            "Percent Difference (Dynamic Price-Amazon_Reference_Price)/Dynamic Price" AS Percent_Diff, 
          /* New_Markup */
            ((t1.Post_Filter-t1.DP_CHAIN_COST)/t1.Post_Filter) FORMAT=PERCENT8.1 LABEL=
            "(DynamicPrice-Chain Cost)/Dynamic Price" AS New_Markup, 
          /* 7_Day_Moving_Avg */
            (t1.MA_7) LABEL="7_Day_Moving_Avg" AS 'Seven_Day_Moving_Avg'n, 
          /* 3_Day_Moving_Avg */
            (t1.MA_3) LABEL="3_Day_Moving_Avg" AS 'Three_Day_Moving_Avg'n, 
          /* Current_Amazon_Price */
            (t1.AFLT_PRICE_AMT) LABEL="Current Competitor Price" AS Current_Comp_Price, 
          /* Amazon_Reference_Price */
            (t1.Reference_Price) LABEL="Competitor Reference Price" AS Comp_Reference_Price, 
          /* BBB_Min_Price */
            (t1.BBB_Min) LABEL="BBB_Min_Price" AS BBB_Min_Price, 
          /* Chain_Retail_Price */
            (t1.DP_CHAIN_RETAIL) LABEL="Chain Retail Price" AS Chain_Retail_Price, 
		  /* Chain to Reg */          
		  /* Regular Retail */
		    (t1.DP_REG_PRICE) LABEL="Regular Retail" AS Regular_Retail,
          /* Chain_Cost */
            (t1.DP_CHAIN_COST) LABEL="Chain Cost" AS Chain_Cost, 
          /* Coupon_Rate */
            (t1.Overall_Coupon_Rate) FORMAT=PERCENT8.0 LABEL="Coupon Rate" AS Coupon_Rate, 
          /* Profit_Buffer */
            (t1.Overall_Break_Even) FORMAT=PERCENT8.0 LABEL="Profit Buffer" AS Profit_Buffer, 
          /* Freight_Rate */
            (t1.SKU_Freight) FORMAT=PERCENT8.0 LABEL="Freight Rate (as a % of Cost)" AS Freight_Rate, 
          /* Vendor_Name */
            (t1.PIM_VENDOR_NAME) LABEL="Vendor Name" AS Vendor_Name, 
			(t1.DP_VENDOR) LABEL="Vendor Code" AS Vendor_Code, 

          /* Markup Above BBB Min */
            ((t1.Post_Filter-t1.BBB_Min)/t1.Post_Filter) FORMAT=PERCENT8.0 LABEL=
            "Markup Above BBB Min (Dynamic Price-BBB Min / Dynamic Price)" AS Markup_Above_BBB_Min, 
          /* Current_Variance */
            ((t1.DP_CUR_WEB_PRICE-t1.Reference_Price)/t1.DP_CUR_WEB_PRICE) FORMAT=PERCENT8.0 LABEL=
            "Current Variance ((BBB-Amazon Reference Price)/BBB)" AS Current_Variance, 
          /* DP_DY_BUS_RSNCD */
            (t1.Reason_Code) LABEL="DP_DY_BUS_RSNCD" AS DP_DY_BUS_RSNCD, 
          /* DP_DY_SET_RULECD */
            (t1.Scenario||'7') LABEL="DP_DY_SET_RULECD" AS DP_DY_SET_RULECD, 
          t1.DP_DY_PRICE_STRTS, 
          t1.DP_ENDTS,
          t1.code_path,
			t1.SKU_sale_Type
	FROM MSWP_reco_file_&today1 t1;
QUIT; 


