         	(Case when t1.BBB_Min GT t1.Reference_Price Then t1.BBB_Min
         	 	Else t1.Reference_Price End) FORMAT=9.2 LABEL="Range_Min" AS Range_Min, 
           	t1.COLLECTION_ITEM_SKU_NUM,
			t1.Code_Path,
	  		t1.Reference_Price_Competitor,
	  		t1.AFLT_PRICE_AMT_Competitor,
			t1.PMR_AFLT_WEB_NM,
	  		t1.Current_Promo_Flag,
			t1.Upcoming_Promo_Filter,
			t1.Regular_Promo_Filter,
			t1.MAP_FLAG,
			t1.EM_FLAG,
			t1.VDC_WEB_FLAG,
