/*finding 10th and 90th percentile by MSWP*/
proc means data=WORK.MSWP_Freight;
	label Gross_Frt_as_a_per_of_merch="Gross_Freight";
	class MS_WPID;
	var Gross_Frt_as_a_per_of_merch;
	output out=MSWP_Percentile P10=P10 P90=P90 n=Count Mean=Mean;
run;

/*finding all values between the 10th and 90th percentile for an MSWP*/
proc sql;
	create table MSWP_Percentile_in as
	select t1.MS_WPID,
			t1.SKU,
			t1.Gross_Frt_as_a_per_of_merch,
			t2.P10, 
			t2.P90
	from WORK.MSWP_Freight t1
	left join MSWP_Percentile t2 on t2.MS_WPID=t1.MS_WPID
	where t2.P10<t1.Gross_Frt_as_a_per_of_merch<t2.P90 and t2.P10 NE .;
quit;

/*finding mean of freight between 10th and 90th percentile by MSWP*/
proc means data=MSWP_Percentile_in;
label Gross_Frt_as_a_per_of_merch="Gross_Freight";
class MS_WPID;
var Gross_Frt_as_a_per_of_merch;
output out=MSWP_P1090_Mean mean=SKU_Freight;
run;

/*getting the freight rate at the MSWP level*/
proc sql;
	create table MSWP_Mean as
	select 	t1.MS_WPID,
			t1.ITEM_SKU_NUM,
			t2.SKU_Freight as P1090_Mean,
			t3.Mean as MSWP_Mean,
			t3.Count as no_SKUs,
			t4.Gross_Frt_as_a_per_of_merch as SKU_Freight_Rate,
			(case when t3.Count>6 then t2.SKU_Freight	   
		   	else t3.Mean end) LABEL ="MSWP_Freight_Rate" as MSWP_Freight_Rate
			/*if the MSWP has more than 6 SKUs w freight, then take P10-90 average, otherwise take the average*/
	from work.Carmen_test /*remove_promo_skus*/ t1
	left join MSWP_Percentile t3 on t3.MS_WPID = t1.MS_WPID
	left join MSWP_P1090_Mean t2 on t2.MS_WPID = t1.MS_WPID
	left join WORK.MSWP_Freight t4 on t4.SKU=t1.ITEM_SKU_NUM ;
quit;

