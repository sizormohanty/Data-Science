/*Putting it all together*/
proc sql; 
	create table WORK.ALL_DATA as
	select t1.dp_department,
	  t1.DEPARTMENT_NAME,
	  t1.sku_ct as JDA_SKU,
	  t1.sku_ct - t2.sku_ct as WO_IS_SKU,
	  t2.sku_ct as Dist_Pim_SKU,
	  t3.sku_ct as Comp_Match_SKU,
	  sum(t2.sku_ct, - t3.sku_ct) as NO_Comp_Match_SKU,
	  t4.sku_ct as Post_Promo_SKU,
	  t3.sku_ct = t4.sku_ct as CHECK2,
	  t555.sku_ct as Exc_List_SKU,
	  t5.sku_ct as Priced_Right_SKU,
	  t6.sku_ct as MAP_SKU,
	  t7.sku_ct as EM_SKU,
	  t8.sku_ct as Promos_SKU,
	  sum(t12.sku_ct, t1240.sku_ct) as Store_Inv_SKU,
	  t13.sku_ct as At_BBBMin_SKU,
	  t14.sku_ct as Price_Increases_SKU,
	  t15.sku_ct as BBMin_SKU,
	  t16.sku_ct as PPC_SKU,
	  t17.sku_ct as RBC_SKU,
	  t18.sku_ct as BPC_SKU,
	  t10.sku_ct as VDC_WEB_SKU_SKU,
	  t11.sku_ct as Chain_Status_SKU,
	  t11a.sku_ct as Coll_excl_SKU,
	  sum(t3.sku_ct, - t555.sku_ct) as CP0_SKU,
	  t181.sku_ct as Post_filter_SKU,
	  t19.sku_ct as Recos_SKU,

	  t20.sku_ct as MSWP_Multiple_MSWP_SKU,
 	  t21.sku_ct as MSWP_Multiple_DP_Reco_SKU,
	  t22.sku_ct as MSWP_Multiple_BBBMin_SKU,
	  t23.sku_ct as MSWP_Multiple_Cost_SKU,
	  t30.sku_ct as MSWP_Final_Set_SKU,	
	  t24.sku_ct as Final_Reco_MSWP_SKU,

	  &today as Date
	from WORK.JDA_Count t1
	left join WORK.DPIM_Count t2 on t1.dp_department=t2.dp_department
	left join WORK.Join_Count t3 on t1.dp_department=t3.dp_department
	left join WORK.Remove_Promo_SKUs_Count t4 on t1.dp_department=t4.dp_department
	left join WORK.Priced_Right_Count t5 on t1.dp_department=t5.dp_department
	left join WORK.Exc_List_Count t555 on t1.dp_department=t555.dp_department	
	left join WORK.MAP_Count t6 on t1.dp_department=t6.dp_department
	left join WORK.EM_Count t7 on t1.dp_department=t7.dp_department
	left join WORK.Promos_Count t8 on t1.dp_department=t8.dp_department
	left join WORK.VDC_WEB_Count t10 on t1.dp_department=t10.dp_department
	left join WORK.Chain_Status_Count t11 on t1.dp_department=t11.dp_department
	left join WORK.Coll_excl_Count t11a on t1.dp_department=t11a.dp_department
	left join WORK.Store_Inv_Count t12 on t1.dp_department=t12.dp_department
	left join WORK.Store_Inv_CP40_Count t1240 on t1.dp_department=t1240.dp_department
	left join WORK.At_BBBMin_Count t13 on t1.dp_department=t13.dp_department
	left join Work.Price_Increases_Count t14 on t1.dp_department=t14.dp_department
	left join WORK.BBMin_Count t15 on t1.dp_department=t15.dp_department
	left join WORK.PPC_Count t16 on t1.dp_department=t16.dp_department
	left join WORK.RBC_Count t17 on t1.dp_department=t17.dp_department
	left join WORK.BPC_Count t18 on t1.dp_department=t18.dp_department
	left join WORK.Post_Filter_check_Count t181 on t1.dp_department=t181.dp_department
	left join WORK.Recos_Count t19 on t1.dp_department=t19.dp_department
	left join WORK.MSWP_Multiple_MSWP_Count t20 on t1.dp_department=t20.dp_department
	left join WORK.MSWP_Multiple_DP_Recos_Count t21 on t1.dp_department=t21.dp_department
	left join WORK.MSWP_Multiple_BBBMin_Count t22 on t1.dp_department=t22.dp_department
	left join WORK.MSWP_Multiple_Cost_Count t23 on t1.dp_department=t23.dp_department
	left join WORK.MSWP_RECOS_SKUs t24 on t1.dp_department=t24.dp_department
	left join WORK.MSWP_Final_Set_Count t30 on t1.dp_department=t30.dp_department;
run;

/* Replace . with 0 */
data WORK.ALL_DATA;
   set WORK.ALL_DATA;
   array change _numeric_;
   do over change;
      if change=. then change=0;
      end;
run ;

/* Putting it together and calculating the waterfall*/
proc Sql;
	Create Table WORK.WATERFALL as
	Select t1.Date,
	  t1.DP_DEPARTMENT,
	  t1.DEPARTMENT_NAME,
	  t1.Dist_Pim_SKU as JDA_SKU,       /* Count of initial distinct skus */
	  t1.NO_Comp_Match_SKU,
	  t1.Comp_Match_SKU, /* Count of skus have competitor matches  */  	  
	  sum(t2.BBB_Min_SKU, t4.BBB_Min_SKU) as BBB_Min_SKU,

	  sum(t2.Guard_Rails_SKU, t4.Guard_Rails_SKU) as Guard_Rails_SKU,

	  sum(t2.Position_Rules_SKU, t4.Position_Rules_SKU) as Position_Rules_SKU,

	  sum(t2.Max_Wkly_Ch_SKU, t4.Max_Wkly_Ch_SKU) as Max_Wkly_Ch_SKU,

	  sum(t2.Overall_Change_SKU, t4.Overall_Change_SKU) as Overall_Change_SKU,

	  sum(t2.Rounding_Rules_SKU, t4.Rounding_Rules_SKU) as Rounding_Rules_SKU,

	  sum(t2.Post_Filter_SKU, t4.Post_Filter_SKU) as Post_Filter_SKU,
	  sum(t2.Post_Filter_SKU, t4.Post_Filter_SKU)= t1.Post_filter_SKU as Post_Filter_CHECK,

	  t1.Priced_Right_SKU,
	  t1.MAP_SKU,
	  t1.EM_SKU,
	  t1.Promos_SKU,
	  t1.Store_Inv_SKU,
	  t1.At_BBBMin_SKU,
	  t1.Price_Increases_SKU,
	  t1.BBMin_SKU,
	  t1.PPC_SKU,
	  t1.RBC_SKU,
	  t1.BPC_SKU,
	  t1.VDC_WEB_SKU_SKU,
	  t1.Chain_Status_SKU,
	  t1.Coll_excl_SKU,
	  t1.CP0_SKU,

	  t1.MSWP_Multiple_MSWP_SKU,
	  t1.MSWP_Multiple_DP_Reco_SKU,
	  t1.MSWP_Multiple_BBBMin_SKU,
	  t1.MSWP_Multiple_Cost_SKU,
	  t4.Post_Filter_SKU = sum(t1.MSWP_Multiple_MSWP_SKU, t1.MSWP_Multiple_DP_Reco_SKU, t1.MSWP_Multiple_BBBMin_SKU,
	  				t1.MSWP_Multiple_Cost_SKU, t1.MSWP_Final_Set_SKU) as CHECK_MSWP,

	  t1.Final_Reco_MSWP_SKU - t1.MSWP_Final_Set_SKU as MSWP_add_back_SKU,	

	  t1.Recos_SKU as Reco_File_SKU
	from WORK.ALL_DATA t1
	left join WORK.Waterfall_1 t2 on t1.dp_department = t2.dp_department
	left join WORK.WATERFALL_3 t4 on t1.dp_department = t4.dp_department;

quit;


/*Calculating the Waterfall Steps*/
proc Sql;
	Create Table WORK.WATERFALL_RESULTS as
	Select t1.Date,
	  t1.dp_department,
	  t1.DEPARTMENT_NAME,
	  t1.JDA_SKU  Label = 'Initial JDA' as Inital_SKU_Count,
	  (-1)* t1.Priced_Right_SKU Label = 'Priced Right' as Priced_right_SKU_Count,
	  (-1)* t1.no_comp_match_SKU Label = 'No Comp Matches' as No_Comp_SKU_Count,
	  (-1)* t1.MAP_SKU Label = 'MAP' as MAP_SKU_Count,
	  (-1)* t1.EM_SKU Label = 'Event Manager' as EM_SKU_Count,
	  (-1)* t1.Promos_SKU Label = 'Promo SKUs' as Promo_SKU_Count,
	  (-1)* t1.Store_Inv_SKU Label = 'Store Inv'  as Store_Inv_SKU_Count,
	  (-1)* t1.At_BBBMin_SKU Label = 'at BBB Min' as At_BBBMin_SKU_Count,
	  (-1)* t1.Price_Increases_SKU Label = 'N/A Price Increases' as Price_Increases_SKU_Count,
	  (-1)* t1.BBMin_SKU Label = 'Buyer Below Min' as BBM_SKU_Count,
	  (-1)* t1.PPC_SKU Label = 'Permanent Price Change' as PPC_SKU_Count,
	  (-1)* t1.RBC_SKU Label = 'Comp Below Cost' as RBC_SKU_Count,
	  (-1)* t1.BPC_SKU Label = 'Bad Price Candidate'  as BPC_SKU_Count,

