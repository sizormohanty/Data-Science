proc sql;
	/*how many SKUs we start with, in the JDA file*/
	create table WORK.JDA_Count as
	select distinct t1.dp_department,
		t2.DEPARTMENT_NAME,
	  count(distinct t1.dp_sku) as sku_ct,
	  "JDA_SKU" as Type length =20
	from WORK.JDA_File t1
	inner join WORK.DEPTS T2 ON t1.DP_DEPARTMENT = T2.DEPARTMENT_CD
	where t1.dp_store=651
	group by t1.dp_department;

	/*How many SKUS are left after merger JDA and PIM File*/
	create table WORK.DPIM_Count as
	select dp_department,
	  count(distinct dp_sku) as sku_ct,
	  "Post_Inv_SKU" as Type length=20
	from WORK.Distinct_PIM
	group by dp_department;

	/* How many SKUS are have Competitor Matches */
	create table WORK.Join_Count as
	select dp_department,
	  count(distinct dp_sku) as sku_ct,
	  "Comp_Match_SKU" as Type length=20
	from WORK.Join
	group by dp_department;

	/*How many SKUS are left after upcoming promotion filter */
	create table WORK.Remove_Promo_SKUs_Count as
	select dp_department,
	  count(distinct dp_sku) as sku_ct,
	  "Post_Promo_SKU" as Type length=20
	from WORK.Remove_Promo_SKUs_temp
	group by dp_department;
quit;

