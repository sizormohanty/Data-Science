/* checking that the waterfall counts are correct */
proc sql;
Create table work.wf_check as 
        Select DISTINCT t1.date , 
                t1.DP_DEPARTMENT, 
	  			t1.CHECK2,
				T2.Post_Filter_CHECK,
				T2.CHECK_MSWP,
				SUM(t3.Inital_SKU_Count, 
					t3.Priced_right_SKU_Count,
					t3.No_Comp_SKU_Count,
					t3.MAP_SKU_Count,
	  				T3.EM_SKU_Count,
					t3.Promo_SKU_Count,
					t3.Store_Inv_SKU_Count,
					T3.At_BBBMin_SKU_Count,
					t3.Price_Increases_SKU_Count,
					t3.BBM_SKU_Count,
					t3.PPC_SKU_Count,
					t3.RBC_SKU_Count,
					t3.BPC_SKU_Count,
					T3.Other_Excl_SKU_Count,
				    T3.RECO_FILE_SKU_CounT )=0  AS CHECK3
        from WORK.ALL_DATA t1 
		LEFT JOIN WORK.WATERFALL T2 ON t1.DP_DEPARTMENT = t2.DP_DEPARTMENT
		LEFT JOIN WORK.WATERFALL_RESULTS T3 ON t1.DP_DEPARTMENT = t3.DP_DEPARTMENT; 
quit;

  

/*counting how many depts have counting mismatches*/
proc sql noprint;
	select count (*)
	into : nn
	from WORK.wf_check
	where  Check2 = 0 or 
		  Post_Filter_CHECK = 0 OR
		  CHECK_MSWP = 0 OR		
		  Check3 = 0;
quit;




/*macro to send email, in case of a waterfall counting mismatch*/

%macro sasmail;
	data _null_;
	FILENAME MYMAIL EMAIL
	to= ("carmen.yanazzo@bedbath.com","Brian.Hansen@bedbath.com","Nancy.Crossen@bedbath.com","sizor.mohanty@bedbath.com", "xi.kang@bedbath.com")
	subject= "Waterfall Mismatch &today1";
	file mymail;
	put " ";
	put "Notification of waterfall counting mismatch ";
	put " ";
	run;
%mend sasmail;

%macro sendme;
	%if &nn = 0 %then %do;
				%end;
				%else %do;	
					%sasmail
				%end;
%mend sendme;

%sendme;
