/*cdy - calculating if an AM or a PM code run  */
%let Time = %sysfunc(time(),time8.0); /*getting current time*/
%let Time_HH = %scan(&Time.,1,:); /*getting current hour*/
%put &time_hh;

data WORK.indicator;
	if (&time_hh>=2 and &time_hh<14) then 
			do;/*AM Run*/
				indicator="AM";
				Reco_start_date = &today2;
				Reco_end_date = Reco_start_date + &minimum_days;
				emailtext = cat("today ", put(Reco_start_date,MMDDYY10.));
				scrape_date_max= &today2;
				scrape_date_min= &today2 - 1;
			end;
	else do;/*PM Run*/
			indicator="PM";
			Reco_start_date = &today2 + 1;
			Reco_end_date = Reco_start_date + &minimum_days;
			emailtext = cat("tomorrow ",put(Reco_start_date,MMDDYY10.));
			scrape_date_max= &today2;
			/*CDY- in the future, scrape date min will only be today. for now, it is today-1*/
			scrape_date_min= &today2 - 1;
		end;
run;

