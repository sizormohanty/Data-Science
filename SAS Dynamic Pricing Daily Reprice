%macro nzSqlDrop(table);
  %local tableExists;
  %let databaseName = %scan(&table.,1,.);
  %let tableName = %scan(&table.,2,.);
  %let qt=%str(%');
  %let qry = select count(*) as table_exists from _v_table where upper(database)=upper(&qt.&databaseName.&qt.) and upper(tablename)=upper(&qt.&tableName&qt.);
  %nzsql(&qry.,table_exists);
  proc sql noprint; select table_exists into :tableExists from table_exists; quit;
  %if &tableExists.=1  %then %do;
    %nzsql(drop table &table.)
  %end;
%mend;


%macro nzsql(query,out,defdb=&db.);
  proc sql noerrorstop;
    options nomprint;
    connect to netezza as nz1 (user=&nzName. password=&nzPass.
               server="&nzServer." database="&defdb.");
    options mprint;
    %if &out.=%then %do;
      execute ( &query. ) by nz1;
    %end; %else %do;
      create table &out. as select * from connection to nz1 (&query.);
    %end;
        %let sqlerror=&sqlxrc.; /*Used for Error-Handling*/
    disconnect from nz1;
  quit;
/*Error Handling*/
%put &sqlerror.;
%if &sqlerror. ne 0 %then %do;
        %abort cancel;
%end;
%mend nzsql;

