#3 Approach: Using Machine Learning tools (Naive Baye's and SVM)

install.packages('RTextTools')
install.packages('e1071')
library('RTextTools')
library('e1071')

pos_comments =  rbind(
  c('Prices are cheaper', 'positive'),
  c('Amazing prices', 'positive'),
  c('Well organized and reasonably priced', 'positive'),
  c('prices are great', 'positive'),
  c('prices are just so awesome', 'positive')
)

neg_comments = rbind(
  c('prices are worst', 'negative'),
  c('prices are better at CVS', 'negative'),
  c('everythign is ridiculously expensive', 'negative'),
  c('prices are very high', 'negative'),
  c('prices suck', 'negative')
)

test_comments = rbind(
  c('Im also pretty sure the prices at CVS when factoring the ExtraBucks, are better', 'negative'),
  c('Lots of great buys like almost giveaway prices on certain things', 'positive'),
  c('Prices are great when the items are on sale. Otherwise the items here are really expensive', 'negative'),
  c('Definitely has the cheaper prices beers in Kips Bay', 'positive'),
  c('prices are not awesome', 'negative')
)

comments = rbind(pos_comments, neg_comments, test_comments)
comments


# build dtm
matrix= create_matrix(comments[,1], language="english", 
                      removeStopwords=FALSE, removeNumbers=TRUE, 
                      stemWords=FALSE) 
matrix
# train the model
mat = as.matrix(matrix)
classifier = naiveBayes(mat[1:10,], as.factor(comments[1:10,2]) )

# test the validity
predicted = predict(classifier, mat[11:15,]); predicted
table(comments[11:15, 2], predicted)
recall_accuracy(comments[11:15, 2], predicted)
predicted

# build the data to specify response variable, training set, testing set.
container = create_container(matrix, as.numeric(as.factor(comments[,2])),
                             trainSize=1:10, testSize=11:15,virgin=FALSE)
models = train_models(container, algorithms=c("MAXENT" , "SVM", "RF", "BAGGING", "TREE"))
results = classify_models(container, models)

# accuracy table
table(as.numeric(as.factor(comments[11:15, 2])), results[,"FORESTS_LABEL"]) # 1= negative 2 = positive
table(as.numeric(as.factor(comments[11:15, 2])), results[,"MAXENTROPY_LABEL"])
table(as.numeric(as.factor(comments[11:15, 2])), results[,"TREE_LABEL"])
table(as.numeric(as.factor(comments[11:15, 2])), results[,"BAGGING_LABEL"])
table(as.numeric(as.factor(comments[11:15, 2])), results[,"SVM_LABEL"])

# recall accuracy
recall_accuracy(as.numeric(as.factor(comments[11:15, 2])), results[,"FORESTS_LABEL"])
recall_accuracy(as.numeric(as.factor(comments[11:15, 2])), results[,"MAXENTROPY_LABEL"])
recall_accuracy(as.numeric(as.factor(comments[11:15, 2])), results[,"TREE_LABEL"])
recall_accuracy(as.numeric(as.factor(comments[11:15, 2])), results[,"BAGGING_LABEL"])
recall_accuracy(as.numeric(as.factor(comments[11:15, 2])), results[,"SVM_LABEL"])























