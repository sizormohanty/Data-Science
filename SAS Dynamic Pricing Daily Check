
/***********************************************************************************
FILE NAME:              Daily Check if AM file was created.
CREATION DATE:          09/12/2016
AUTHOR:                 Sizor Mohanty/Nancy Crossen
PURPOSE:                This module will check if the AM repricing job was created successfully.  If not, it will
                        send an email with the reco file numbers from the PM run of the prior day.
3/22/2017               Add code for the milestone email   .
                       Note: when we only have 1 run, the reco run date is not available for the milestone check */
***********************************************************************************/
options SASTRACE=',,,d' SASTRACELOC=SASLOG NOSTSUFFIX obs=max mprint symbolgen mlogic
        stimer fullstimer msglevel=i debug="PREFETCH(unique_mac,2,SEQUENTIAL)"
        spdedebug='cache_disable'  ;


%let pgmpath=/sasdata/data04/price_auto/codes;
%include "&pgmpath/price_setup.sas";


data depts;
     set stgntz.dy_price_depts;
/*where dept_live = 'Y';*/
run;



%macro checkfile;
%put &reco_dir./&reco_file_AM.;
%if %sysfunc(exist(a.reco_report_&mth.&dy.&yr.am)) %then %do;
     	%put "AM File was created";
		%let file_check_AM=1;
	%end;
    %else %do;
		/*	%include "&pgmPath/price_test_email.sas";**/
		%put "Missing AM";   
	%end;

%if %sysfunc(exist(a.reco_report_&mth_yesterday.&dy_yesterday.&yr_yesterday.pm)) %then %do;
		 %put "PM File was created";
		 %let file_check_PM=1;
	%end;
    %else %do;
      	/*%include "&pgmPath/price_test_email.sas";*/
		%put  "Missing PM";       
	%end;
%mend;


%checkfile;

%put &reco_file_AM. &reco_file_PM. &file_check_PM &file_check_AM;
%macro combine_recos     ;

%if &indicator. = AM %then %do;


	%if &file_check_AM=0 and &file_check_PM=0 %then %do;
              %let statement="input files not received for today." ;
		%put %statement;
                %abort cancel;
	%end;


	%if &file_check_AM=0 and &file_check_PM=1 %then %do;
		%put "AM File not created. PM file was created. Use dummy file to create empty AM file ";
		data  a.reco_report_&mth.&dy.&yr.am;
                   set a.reco_report_dummy;
		 run;
                   %let  file_check_AM=1;
               	%end;


	%if &file_check_AM=1 and &file_check_PM=0 %then %do;
		%put "PM File not created. AM file was created. Use dummy  file to create empty PM file";
		 data  a.reco_report_&mth_yesterday.&dy_yesterday.&yr_yesterday.pm;
                    set a.reco_report_dummy;
               run;
           %let  file_check_PM=1;
	%end;


	%if &file_check_AM=1 and &file_check_PM=1 %then %do;
		%put "Both files were created.";
	
    	proc sort data=a.reco_report_&mth_yesterday.&dy_yesterday.&yr_yesterday.pm out =PM_REPORT;
        	by sku_num ;
    	proc sort data=a.reco_report_&mth.&dy.&yr.am out =AM_REPORT;
        	by sku_num;
    	data final_report;
        	merge PM_REPORT (in=a)
         	      AM_REPORT (in=b);
         	by sku_num;
         	if a or b;
			drop cnt;
    	run;

		proc sort data=final_report ;
     	   by sku_num;
		   run;
  data a.final_reco_report_&mth.&dy.&yr.;
    set final_report;
    cnt +1;
run;

/*   add code to indicate that the PM reco was effective or not    */

/*   get yesterday's PM recos                                      */  
data PM_RECOS;
      set tmp00001.reco0;
	     where reco_run_date = today()-1  and indicator = 'PM';
run;
/* get recos where AM price overrides PM   */

data OVERLAY_RECO ;
      set final_report;
	     where indicator = 'AM';
		 keep SKU_num;
run;
proc sort data=PM_RECOS;
  by sku_num;
run;

proc sort data=overlay_reco;
    by sku_num;
run;
/* These are the recos that need to be reset in the archive.   */

data overlay_reco2;
     merge overlay_reco (in=a)
	       pm_recos   (in=b);
	by sku_num;
	if a and b;
	effective_reco = 'N';
run;

proc sort data=overlay_reco2;
    by reco_run_date sku_num;
run;
proc sort data=tmp00001.reco0    out=sorted_archive;
   by reco_run_date sku_num;
run;

data new_archive;
     merge sorted_archive (in=a)
	        overlay_reco2 (in=b);
		by reco_run_date sku_num;
		if a;
    if a and b and indicator = 'PM'
      then do; 
            effective_reco = 'N';
           end;

run;

	%end;
%end;

proc freq data=new_archive;
     tables effective_reco/missing list;
run;
data tmp00001.reco0;
     set new_archive;
run;

%mend;
%combine_recos          ;




