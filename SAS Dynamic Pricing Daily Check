/*  Add code for milestone email   */

PROC SQL;
   CREATE TABLE WORK.reco_count AS
   SELECT count(*) as reco_count 
      FROM a.final_reco_report_&mth.&dy.&yr. ;

QUIT;

proc sql noprint;
    select reco_count
	  into :today_reco
	   from work.reco_count;
quit;
%put today_reco &today_reco;
/* get total recos for today  */

data all_recos;
     set new_archive;
	    where (indicator = 'PM' and reco_run_date = &today2-1) or
		       (indicator = 'AM' and reco_run_date = &today2);
run;


data _null_;
     if 0 then set WORK.all_recos nobs=n;
     call symput('reco_count_oneday',n);
     stop;
run;
%put reco_count_oneday &reco_count_oneday.;



/* get total recos in the archive */
data  total_sku_cnt (keep=sku_num reco_run_date indicator effective_reco);
	 set    new_archive;
run;
data _null_;
     if 0 then set WORK.total_sku_cnt nobs=n;
     call symput('total_all',n);
     stop;
run;
data eff_sku_cnt;
     set total_sku_cnt;
	       where effective_reco='Y';
		   
run;
data _null_;
     if 0 then set WORK.eff_sku_cnt nobs=n;
     call symput('total_eff',n);
     stop;
run;
%put &total_eff. &total_all.;

data _null_;
      reco_count = &today_reco;
     reco_count_oneday = &reco_count_oneday.;
     remainder=mod(&total_eff.,1000000);
	 quotient=int(&total_eff./1000000);
	 call symputx('rem_eff',remainder);
	 call symputx('quo_eff',quotient);
	  eff_diff = remainder-reco_count;
	 remainder=mod(&total_all.,1000000);
	 quotient=int(&total_all./1000000);
	 call symputx('rem_all',remainder);
	 call symputx('quo_all',quotient);
	
	 all_diff=remainder-reco_count_oneday;
	 call symputx('all_diff',all_diff);
	 call symputx('eff_diff',eff_diff);
	 all_ind = 0;
	 eff_ind = 0;
	 if all_diff < 0 then all_ind = 1;
	 if eff_diff < 0 then eff_ind = 1;
     call symputx('all_ind',all_ind);
	 call symputx('eff_ind',eff_ind);
	 	 
run;
%put rem_eff &rem_eff. quo_eff &quo_eff. eff_diff &eff_diff. 
     rem_all &rem_all.  quo_all &quo_all. all_diff &all_diff. 
     today_reco_cnt &today_reco. eff_ind &eff_ind. all_ind &all_ind. ;

