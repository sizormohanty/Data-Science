  var Average_freshman_graduation_rate Capital_outlay Instruction_Expenditure other_expenses
 Per_eligible_free_or_reduc_lunch Poverty_rate_of_5_to_17_year Pupil_teacher_ratio_Fall_2012 Student_staff_ratio_Fall_2012;
  histogram / cfill=gray;
