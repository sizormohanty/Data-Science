proc reg;
model Y=X1 X2 X3 X4 X5 X6 X7 /selection=forward;
proc reg;
model Y=X1 X2 X3 X4 X5 X6 X7 /selection=backward;
proc reg data=raw_data1;
model Y=X1 X2 X3 X4 X5 X6 X7 /clb cli clm;
plot pred.*Y;
plot Y*(X1 X2 X3 X4 X5 X6 X7);
plot residual.*(X1 X2 X3 X4 X5 X6 X7);
plot lcl.*(X1 X2 X3 X4 X5 X6 X7) ucl.*(X1 X2 X3 X4 X5 X6 X7)/overlay;
plot lclm.*(X1 X2 X3 X4 X5 X6 X7) uclm.*(X1 X2 X3 X4 X5 X6 X7)/overlay;
model Y=X1 X2 X3 X4 X5 X6 X7 /lackfit XPX I p r;
***/The next two lines test if betta1=0 and if betta1=1/***;
test X1=0,X2=0,X3=0,X4=0,X5=0,X6=0,X7=0;
test X1+X2+X3+X4+X5+X6+X7=1;
***/This section of code gives you 3 different tests for equality of variance, generates
residuals and also does the Shapiro Wilks test on the residuals/***;
proc glm data=raw_data1;
class X1 X2 X3 X4 X5 X6 X7;
model Y=X1 X2 X3 X4 X5 X6 X7;
means X1 X2 X3 X4 X5 X6 X7 /hovtest=levene;
means X1 X2 X3 X4 X5 X6 X7 /hovtest=bartlett;
means X1 X2 X3 X4 X5 X6 X7 /hovtest=obrien;
proc reg;
model Y=X2 X3 X6 X7/p;
output out=resid r=r p=p;
plot (p. r.)*(X2 X3 X6 X7) p.*Y r.*p.;
proc univariate data=resid normal plot;
var r;
qqplot r /normal;
proc print;
proc plot;
plot Y*(X1 X2 X3 X4 X5 X6 X7);
plot order*Y;
run;
quit;
