data raw_data1(rename=(Average_freshman_graduation_rate=Y
 per_eligible_free_or_reduc_lunch=X6 
 Poverty_rate_of_5_to_17_year=X7));
set raw_data;
X1=round(log10(Capital_outlay),0.01);
X2=round(log10(Instruction_Expenditure),0.01);
X3=round(log10(other_expenses),0.01);
X4=round(log10(Pupil_teacher_ratio_Fall_2012),0.01);
X5=round(log10(Student_staff_ratio_Fall_2012),0.01);
label Average_freshman_graduation_rate='Avg_grad_rate'
       X1='log_cap_outlay' X2='log_inst_Exp' X3='Log_other_exp' X4='Log_pupil_teacher' X5='log_stud_staff'
        Per_eligible_free_or_reduc_lunch='Reduced_lunch' 
 Poverty_rate_of_5_to_17_year='Poverty_rate' ;
drop Capital_outlay Instruction_Expenditure other_expenses Pupil_teacher_ratio_Fall_2012 Student_staff_ratio_Fall_2012;
run;

