data _null_;
call symput('Tdate', put(today(), date7.));
run;
%put &Tdate; 





proc sql; select max(Effective_Date) into : Ef_TDate from Arc.DP_Recos; quit;
%put &Ef_TDate; 

%let NEf_TDate = %str(%')%sysfunc(intnx(day,"&Tdate."d,0),YYMMDD10.)%str(%');
%put &NEf_TDate;




proc sql;
create table StarS.StarS_Reco_&Tdate as
select distinct 
a.Multi_SKU_Web_Product_ID,
a.Collection_Num,
a.SKU_num,
a.SKU_Description,
a.Department_CD,
a.Current_Web_Price format dollar10.2,
a.Dynamic_Price_Recommendation format dollar10.2,
a.Seven_Day_Moving_Avg format dollar10.2,
a.Three_Day_Moving_Avg format dollar10.2,
a.Current_Comp_Price format dollar10.2,
a.Comp_Reference_Price format dollar10.2,
a.BBB_Min_Price format dollar10.2,
a.Chain_Retail_Price format dollar10.2,
a.Regular_Retail format dollar10.2,
a.Chain_Cost format dollar10.2,
a.Vendor_Name,
a.DP_DY_BUS_RSNCD,
a.Effective_Date,
a.End_Date,
a.indicator,
a.Code_Path,
a.SKU_Sale_Type,
case when (a.Dynamic_Price_Recommendation < a.Chain_cost and a.effective_reco ='Y') then 'Y'
	else 'N'
end as BelowCost,  
case when (b.BBBY_Web_Offered_IND = 'Y' and b.BBBY_Web_DIsable_IND = 'N' 
		and b.BBBY_WEB_ENABLE_DT not = . AND b.BBBY_WEB_OFFERED_DT not = . ) then 'Y'
	else 'N'
end as On_Site_Today
from Arc.DP_Recos a
left join PIM_FILE b 
	on a.SKU_Num = b.Item_SKU_Num
where a.code_path = '35' and a.effective_date=&Ef_TDate and a.effective_reco = 'Y';
quit;



proc sql;
create table StarS.StarS_BelowCost_&Tdate as
select distinct *
from StarS.StarS_Reco_&Tdate
where BelowCost = 'Y'
order by SKU_num;
quit;







