          t1.DP_CHAIN_COST, 
          t1.DP_REG_PRICE, 
          t1.DP_CUR_WEB_PRICE, 
          t1.DP_PROMO_PRC, 
          t1.DP_PROMO_STRT_DT, 
          t1.DP_PROMO_END_DT, 
          t1.DP_NEXT_PROMO_RSNCD,
          T1.DP_NEXT_PROMO_STRDT,
          t1.DP_NEXT_PROMO_ENDDT,
          t1.BBB_PRICE_AMT, 
