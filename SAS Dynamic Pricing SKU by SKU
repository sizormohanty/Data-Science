/*Calculating freight Rate*/

/*Common SKUs*/
PROC SQL;
   CREATE TABLE WORK.Common_SKUs AS 
   SELECT DISTINCT 
		t2.DP_STORE, 
        t2.DP_SKU, 
        t2.DP_DEPARTMENT, 


        t2.DP_SUB_DEPARTMENT, 
        t2.DP_CLASS, 
        t2.DP_VENDOR, 
        (t1.Gross_Frt_as_a_per_of_merch) FORMAT=12.2 LABEL="SKU_Freight" AS SKU_Freight
   FROM WORK.Freight_Rate t1, 
			WORK.REMOVE_PROMO_SKUS t2
   WHERE (t1.SKU = t2.DP_SKU);
QUIT;
PROC SQL;
   CREATE TABLE WORK.Uncommon_SKUs AS 
   SELECT DISTINCT t2.DP_STORE, 
          t2.DP_SKU, 
          t2.DP_DEPARTMENT, 
          t2.DP_SUB_DEPARTMENT, 
          t2.DP_CLASS, 
          t2.DP_VENDOR
   FROM WORK.Freight_Rate t1
   RIGHT JOIN WORK.REMOVE_PROMO_SKUS t2 ON  (t1.SKU = t2.DP_SKU)
   WHERE t1.SKU = .;
QUIT;

PROC SQL;
   CREATE TABLE WORK.VDC_Freight_Costs AS 
   SELECT DISTINCT t1.Vendor_Number, 
            (AVG(t1.Gross_Frt_as_a_per_of_merch)) FORMAT=BEST12. AS AVG_Gross_Frt_per_of_Merch    
   FROM WORK.DISTINCT_PIM t2
   INNER JOIN WORK.Freight_Rate t1 ON (t2.ITEM_SKU_NUM = t1.SKU)
   GROUP BY t1.Vendor_Number;
QUIT;

PROC SQL;
   CREATE TABLE WORK.Distinct_Classes AS 
   SELECT DISTINCT (put(t1.department_cd,3.)||put(t1.sub_department_cd,3.)||put(t1.class_cd,3.)) LABEL=
                     "Distinct_Classes" AS Distinct_Classes, 
            (AVG(t1.Gross_Frt_as_a_per_of_merch)) FORMAT=BEST12. AS AVG_Gross_Frt_per_of_Merch            
   FROM WORK.Freight_Rate    t1
   GROUP BY (CALCULATED Distinct_Classes);
QUIT;

PROC SQL;
   CREATE TABLE WORK.Distinct_Classes_Uncommon(label="Distinct_Classes_Uncommon") AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_SKU, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          (put(t1.DP_DEPARTMENT,3.)||put(t1.DP_SUB_DEPARTMENT,3.)||put(t1.DP_CLASS,3.)) LABEL="Distinct" AS Distinct
   FROM WORK.UNCOMMON_SKUS t1;
QUIT;
PROC SQL;
   CREATE TABLE WORK.Freight_by_Class(label="Freight_by_Class") AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_SKU, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          (0) FORMAT=12.2 LABEL="Avg_Vendor" AS Avg_Vendor,
          (t2.AVG_Gross_Frt_per_of_Merch ) FORMAT=12.2 LABEL="Avg_Class" AS Avg_Class
   FROM WORK.DISTINCT_CLASSES_UNCOMMON t1
   INNER JOIN WORK.DISTINCT_CLASSES t2 ON (t1.Distinct = t2.Distinct_Classes);
QUIT;

PROC SQL;
   CREATE TABLE WORK.Non_Class_SKUs(label="Non-Class_SKUs") AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_SKU, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          t1.Distinct, 
          t2.AVG_Gross_Frt_per_of_Merch               
      FROM WORK.DISTINCT_CLASSES_UNCOMMON t1
           LEFT JOIN WORK.DISTINCT_CLASSES t2 ON (t1.Distinct = t2.Distinct_Classes)
      WHERE t2.Distinct_Classes = '';
QUIT;

PROC SQL;
   CREATE TABLE WORK.Freight_by_Class(label="Freight_by_Class") AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_SKU, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          (0) FORMAT=12.2 LABEL="Avg_Vendor" AS Avg_Vendor, 
          (t2.AVG_Gross_Frt_per_of_Merch) FORMAT=12.2 LABEL="Avg_Class" AS Avg_Class
   FROM WORK.DISTINCT_CLASSES_UNCOMMON t1
   INNER JOIN WORK.DISTINCT_CLASSES t2 ON (t1.Distinct = t2.Distinct_Classes);
QUIT;

PROC SQL;
   CREATE TABLE WORK.Non_Class_Vendor_Freight(label="Non-Class_SKUs_Vendors") AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_SKU, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          (t2.AVG_Gross_Frt_per_of_Merch)  FORMAT=12.2 LABEL="Avg_Vendor" AS Avg_Vendor, 
          (0) FORMAT=12.2 LABEL="Avg_Class" AS Avg_Class
   FROM WORK.VDC_FREIGHT_COSTS t2
   INNER JOIN WORK.NON_CLASS_SKUS t1 ON (t2.Vendor_Number = t1.DP_VENDOR);
QUIT;

PROC SQL;
	CREATE TABLE WORK.Freight_by_Class_vendor AS 
	SELECT * FROM WORK.NON_CLASS_VENDOR_FREIGHT
 	OUTER UNION CORR 
	SELECT * FROM WORK.FREIGHT_BY_CLASS;
Quit;

PROC SQL;
   CREATE TABLE WORK.Freight_Uncommon_SKUs(label="Freight_Uncommon_SKUs") AS 
   SELECT DISTINCT t1.DP_STORE, 
          t1.DP_SKU, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          (Case When t1.Avg_Vendor GT 0 AND t1.Avg_Class GT 0 Then (t1.Avg_Vendor+t1.Avg_Class)/2
                When t1.Avg_Vendor EQ 0 AND t1.Avg_Class GT 0 Then (t1.Avg_Class)
           		Else t1.Avg_Vendor End) FORMAT=12.2 LABEL="SKU_Freight" AS SKU_Freight
   FROM WORK.FREIGHT_BY_CLASS_VENDOR t1;
QUIT;

PROC SQL;
	CREATE TABLE WORK.SKU_Freight AS 
	SELECT * FROM WORK.COMMON_SKUS
	OUTER UNION CORR 
	SELECT * FROM WORK.FREIGHT_UNCOMMON_SKUS;
Quit;








/****** SM - SKU by SKu Coupon Rate Start ************************/

data WORK.coupon_rate;
	set WORK.coupon_rate;
	dp_sku_class=put(department_cd,3.)||"-"||put(sub_department_cd,3.)||"-"||put(class_code,3.);
	dp_dept_vendor=put(department_cd,3.)||"-"||cats(put(vendor_cd,8.));
run;

data WORK.remove_promo_skus;
	set WORK.remove_promo_skus;
	dp_sku_class=put(dp_department,3.)||"-"||put(dp_sub_department,3.)||"-"||put(dp_class,3.);
	dp_dept_vendor=put(dp_department,3.)||"-"||cats(put(dp_vendor,8.));
run;

/*finding all values between the 10th and 90th percentile for class*/

proc means data=WORK.coupon_rate mean sum P10 P90 N noprint missing;
	var coupon_rate;
	class dp_sku_class;
	output out=WORK.coupon_rate_class (drop=_type_ _freq_) 
	P10=P10_Class P90=P90_Class Mean=mean_Class;
run;


proc sql;
	create table WORK.coupon_rate_class as
	select distinct t1.dp_sku_class, 
				avg(t1.coupon_rate) as Mean_class
	from WORK.coupon_rate t1
	left join WORK.coupon_rate_class t2 on t2.dp_sku_class=t1.dp_sku_class
	where t2.P10_Class<t1.coupon_rate<t2.P90_Class and t2.P10_Class NE .
	group by t1.dp_sku_class;
quit;


/*finding all values between the 10th and 90th percentile for vendor*/
proc means data=WORK.coupon_rate mean sum P10 P90 N noprint missing;
	var coupon_rate;
	class dp_dept_vendor;
	output out=coupon_rate_vendor (drop=_type_ _freq_) 
	P10=P10_vendor P90=P90_vendor Mean=mean_vendor;
run;
proc sql;
	create table WORK.coupon_rate_vendor as
	select distinct t1.dp_dept_vendor, 
				avg(t1.coupon_rate) as Mean_vendor
	from coupon_rate t1
	left join WORK.coupon_rate_vendor t2 on t2.dp_dept_vendor=t1.dp_dept_vendor
	where t2.P10_vendor<t1.coupon_rate<t2.P90_vendor and t2.P10_vendor NE .
group by t1.dp_dept_vendor;
quit;

proc sql;
create table remove_promo_SKU as
select DISTINCT t1.DP_STORE, 
          t1.DP_DEPARTMENT, 
          t1.DP_SUB_DEPARTMENT, 
          t1.DP_CLASS, 
          t1.DP_VENDOR, 
          t1.MS_WPID, 
          t1.DP_SKU, 
