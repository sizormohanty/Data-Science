          t1.Overall_Freight, 
		  (Case when t1.overall_coupon_rate = 0 then 0
	  		when t2.coupon_rate<>. then t2.coupon_rate
      		when (t2.coupon_Rate=. and t3.mean_class<>.) then t3.mean_class
	  		when (t2.coupon_Rate=. and t3.mean_class=. and t4.mean_vendor<>.) then t4.mean_vendor 
	  		when (t2.coupon_Rate=. and t3.mean_class=. and t4.mean_vendor=.) then t1.overall_coupon_rate
      	  end) as Overall_coupon_rate,
	  	  t1.overall_coupon_rate as overall_coupon_rate1,
	  	  t2.Coupon_rate,
	  	  t3.mean_class,
	  	  t4.mean_vendor,
          t1.Overall_Break_Even, 
          t1.BUYER_NUMBER, 
          t1.BUYER_NAME, 
          t1.DP_SELL_BUY_FAC, 
          t1.Current_Promo_Flag, 
          t1.Upcoming_Promo_Filter, 
          t1.Regular_Promo_Filter, 
          t1.DP_REG_STRT_DT, 
          t1.COLLECTION_ITEM_SKU_NUM,
		  t1.LTL_IND,
		  t1.MAP_PRC_AMT,
		  t1.Code_Path,
	 	  t1.PIM_BRAND_CD,
	 	  t1.SKU_TYPE,
	   	  t1.PIM_BRAND_NAME,
	   	  t1.DP_VENDOR_NAME,
          t1.Reference_Price_Competitor,
	  	  t1.AFLT_PRICE_AMT_Competitor,
		  t1.No_Online_Inv_Flag,
		  t1.MAP_FLAG,
		  t1.EM_FLAG,
		  t1.VDC_WEB_FLAG,
		  t1.Coll_excl_Flag,
		  t1.DP_CHAIN_STATUS,
		  t1.Chain_Status_Flag,
  		  t1.VDC_IND, 
	      t1.Web_Only_Ind, 
	      t1.In_Store_Ind,
		  t1.SKU_sale_Type,
		  t1.dp_sku_class,
		  t1.dp_dept_vendor
from remove_promo_skus t1
left join coupon_rate t2 on (t1.dp_sku=t2.sku_num)
left join coupon_rate_class t3 on (t1.dp_sku_class=t3.dp_sku_class)
left join coupon_rate_vendor t4 on (t1.dp_dept_vendor=t4.dp_dept_vendor);
quit;

